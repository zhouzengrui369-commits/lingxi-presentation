{
  "appId": "com.lingxi.desktop",
  "productName": "灵犀演示",
  "directories": {
    "output": "dist/windows"
  },
  "files": [
    "windows/Release/**/*",
    "package.json"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true
  }
}
