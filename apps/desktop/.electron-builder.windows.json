{
  "appId": "com.lingxi.desktop",
  "productName": "灵犀演示",
  "directories": {
    "output": "dist/windows"
  },
  "main": "electron-shell/main.js",
  "files": [
    "electron-shell/main.js",
    "electron-shell/preload.js",
    "electron-shell/dist/**/*",
    "electron-shell/src/**/*",
    "electron-shell/package.json",
    "package.json"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true
  }
}
