{
  "name": "lingxi-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "灵犀演示 — AI 驱动的办公内容生成桌面 App（macOS + Windows）",
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "macos": "react-native run-macos",
    "windows": "react-native run-windows",
    "start": "react-native start",
    "test": "jest",
    "test:advisor": "jest --config jest.config.advisor.js",
    "test:template": "jest --config jest.template.config.js",
    "lint": "eslint .",
    "cli:template": "tsx src/modules/template/cli.ts",
    "build:macos": "cd macos && xcodebuild -workspace LingxiDemo.xcworkspace -scheme LingxiDemo -configuration Release",
    "build:windows": "cd windows && msbuild LingxiDemo.sln /p:Configuration=Release"
  },
  "dependencies": {
    "@react-native/new-app-screen": "0.86.0",
    "@types/node": "^22.20.1",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "^5.5.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.23.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/eslint-config": "0.86.0",
    "@react-native/metro-config": "0.86.0",
    "@react-native/typescript-config": "0.86.0",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.7.0",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
