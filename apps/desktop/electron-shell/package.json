{
  "name": "lingxi-demo-electron",
  "productName": "灵犀演示",
  "version": "0.3.0",
  "description": "灵犀演示 — macOS Electron shell wrapping T-2.2 cli/full-demo.ts (T-3.1 platform verification) + T-6.1 5-route RN renderer bridge",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build:renderer": "vite build",
    "build:renderer:dev": "vite",
    "build:mac": "electron-builder --mac dmg --arm64 --publish=never",
    "dist:mac": "electron-builder --mac dir --arm64 --publish=never",
    "test:naming": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.electron.js naming.test.ts",
    "test:bridge": "jest --config jest.config.bridge.js"
  },
  "build": {
    "appId": "com.openclaw.lingxi",
    "productName": "灵犀演示",
    "copyright": "Copyright © 2026 NJX",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.html",
      "dist/renderer.bundle.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../",
        "to": "lingxi-runtime/apps/desktop",
        "filter": [
          "cli/**/*",
          "src/**/*",
          "testdata/quarterly_review/**/*",
          "testdata/templates/business-dark.pptx",
          "node_modules/**/*",
          "package.json",
          "package-lock.json",
          "tsconfig.json",
          "jest.config.js"
        ]
      },
      {
        "from": "../../../backend",
        "to": "lingxi-runtime/backend"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "dir"
      ],
      "icon": "../src/assets/icon-1024.png",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null,
      "extendInfo": {
        "CFBundleDisplayName": "灵犀演示",
        "CFBundleName": "灵犀演示",
        "LSMinimumSystemVersion": "11.0"
      }
    },
    "dmg": {
      "title": "灵犀演示 ${version}",
      "icon": "../src/assets/icon-1024.png",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "asar": false
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.20.1",
    "@vitejs/plugin-react": "^4.3.3",
    "dmg-license": "^1.0.11",
    "electron": "33.4.11",
    "electron-builder": "^25.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-native-web": "^0.19.13",
    "vite": "^5.4.10"
  }
}