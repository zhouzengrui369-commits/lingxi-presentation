{
  "name": "lingxi-demo-electron",
  "version": "0.1.0",
  "description": "灵犀演示 — macOS Electron shell wrapping T-2.2 cli/full-demo.ts (T-3.1 platform verification)",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac --x64 --arm64",
    "build:mac-dmg": "electron-builder --mac dmg"
  },
  "build": {
    "appId": "com.openclaw.lingxi",
    "productName": "灵犀演示",
    "copyright": "Copyright © 2026 NJX",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "main.js",
      "renderer.html",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../",
        "to": "lingxi-runtime/apps/desktop",
        "filter": [
          "cli/**/*",
          "src/**/*",
          "testdata/quarterly_review/**/*",
          "testdata/templates/business-dark.pptx",
          "node_modules/**/*",
          "package.json",
          "package-lock.json",
          "tsconfig.json",
          "jest.config.js"
        ]
      },
      {
        "from": "../../../backend",
        "to": "lingxi-runtime/backend"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ],
      "icon": "../src/assets/icon-1024.png",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null,
      "extendInfo": {
        "CFBundleDisplayName": "灵犀演示",
        "LSMinimumSystemVersion": "11.0"
      }
    },
    "dmg": {
      "title": "灵犀演示 ${version}",
      "icon": "../src/assets/icon-1024.png",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0"
  }
}