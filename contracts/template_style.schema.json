{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lingxi.local/contracts/template_style.schema.json",
  "title": "TemplateStyle",
  "description": "PPTX 模板风格分析结果（T-1.3 模板导入与适配）。style_analyzer 把 .pptx 解析后通过 AI/启发式分析，得到版式类型 + 主辅色 + 字体 + 装饰元素。preview.renderer 用 template_id 引用 builtin_business_*, 用户导入的模板用动态 ID。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "template_id",
    "source",
    "name",
    "layout_types",
    "palette",
    "fonts",
    "decorations",
    "page_count",
    "analyzed_at",
    "analyzer_version"
  ],
  "properties": {
    "template_id": {
      "type": "string",
      "minLength": 1,
      "description": "模板唯一 ID。内置主题用 builtin_business_light / builtin_business_dark；用户导入的用 'imported_' + sha1(8) 前缀"
    },
    "source": {
      "type": "string",
      "enum": ["builtin", "imported"],
      "description": "builtin = 内置简约商务主题；imported = 用户导入的 .pptx"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "模板展示名（内置= '简约商务浅色/深色'；导入= PPT 内置标题或文件名去后缀）"
    },
    "layout_types": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["title", "section", "content", "two_column", "quote", "summary", "blank", "image_focus", "chart", "table"]
      },
      "description": "版式类型集合（去重，按出现频率排序）。生成内容时按版式选最接近的 slide"
    },
    "palette": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary", "secondary", "accent", "background", "text"],
      "properties": {
        "primary": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$",
          "description": "主色（出现频率最高的填充色）"
        },
        "secondary": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$",
          "description": "辅色（次高频率色）"
        },
        "accent": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$",
          "description": "强调色（点缀/链接/标题色）"
        },
        "background": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$",
          "description": "背景色（slide 底色）"
        },
        "text": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$",
          "description": "正文字色"
        }
      },
      "description": "5 色主调色板（与版式绑定，AI 生成内容时优先使用）"
    },
    "fonts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["heading", "body"],
      "properties": {
        "heading": {
          "type": "string",
          "minLength": 1,
          "description": "标题字体（出现频率最高的标题字体名）"
        },
        "body": {
          "type": "string",
          "minLength": 1,
          "description": "正文字体"
        }
      },
      "description": "字体家族（heading vs body 分开定义）"
    },
    "decorations": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["gradient", "solid_block", "border", "shadow", "rounded", "line_accent", "watermark", "icon"]
      },
      "description": "装饰元素集合（去重）。生成内容时复用同样的视觉风格"
    },
    "page_count": {
      "type": "integer",
      "minimum": 1,
      "description": "模板总页数"
    },
    "analyzed_at": {
      "type": "string",
      "format": "date-time",
      "description": "分析完成时间，ISO 8601"
    },
    "analyzer_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "分析器版本号（semver）。内置主题固定 '1.0.0'；导入模板与 style_analyzer.ts 版本绑定"
    }
  }
}
